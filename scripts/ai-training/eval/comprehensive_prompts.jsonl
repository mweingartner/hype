{"id": "btn-go-next", "category": "script-attach", "prompt": "Make button 'play' go to the next card when clicked. Attach the script.", "must_contain": ["set_part_property", "play", "script", "go next"], "must_not_contain": ["function ", "addEventListener", "self.", "hype.show", "let "]}
