wkMP0RuqQBNDvaWz\/S+UmJ0zugApJOAi3D90C3R7ttJ3plTHztp+\/LHNVPOkIIsiKWAxXUcU05gDQqYjlQQR3XlANIoyKe3gH+LqT3QM6Bm\/4ITV8A3wN6D6gHFgLT94AKyDnJvIoc4NnlZMqBHI68ihzg2eVk8nchvQdyHFAP5HDkVfge0HuAp46Z6gGkURHLgQrquKYcQBoVsRyooI5rygGkURHzdyG9B3L8Ug\/kcORV+B7Qe4CnjpnqAaRREcuBCuq4phxAGhWxHKigjmvKAaRREfN3Ib0HcvxSD+Rw5FX4HtB7gKeOmeoBpFERy4EK6rimHEAaFXHMgWYfm82NxjaTggMjrdHYQC5WgP9Hwn\/FsH4e+1jWt0M\/9l8J3yj544pwjb+tH96IJv4zAl9qwGIIzT8fmwAAAABJRU5ErkJggg==","name":"hype_barrel_ladder","width":48}]},"aiPromptHistory":["The ghosts in the sprite area are not roaming the entire map. Fix that.","now the ghosts just stop when they encounter a wall. That is no better","Have the start game button fully reset the map, including all dots and power ups to collect.","add these scripts for me please","take a look at the screen. you've created too many dots and they don't align with the paths within the maze. That needs correcting","pacman no longer eats the dots, causing them to disapear as he goes over them and incrementing his score.","Create a SpriteKit based game on the current card in the style of Donkey Kong. Set the play area to 800w x 600h. Create all necessary assets with the image generation AI API. Create all game logic as scripts attached to the sprite scene you create. Add a button for \"New Game\" that resets the game state to the starting state. Use the WASD keys to move the main character and the space key to make him jump barrels. Fully test the result and fix all errors until it works and looks correctly.","jumping is not working. the player must be able to jump sufficiently to clear the barrels.","I don't see the new game button anywhere","ensure that the game state resets to the beginning when the New Game button is clicked","the player movement with WASD and the space bar is not working and the game state does not seem to reset when clicking the \"New Game\" button","all barrels must start at the top of the window and be \"tossed\" down the levels of the game by the gorilla at the top. make these changes","the button send \"newGame\" to the spriteArea but the spriteArea does not have a newGame script that I see that will reset game state. Make sure that script exists","fix player movement. the WASD key movement and space bar jumping are not controlling the character","what templates are available to help build different game types in Hype?"],"stack":{"networkManifest":{"outboundHostRules":[],"savedListeners":[]},"themeName":"System","height":600,"width":800,"webAssetsAllowed":false,"meshyEnabled":false,"name":"Pac-Man Accessibility Testbed","modifiedAt":800590214.187368,"script":"","defaultFont":"Apple Braille","createdAt":800590214.187368,"id":"7FAC2126-3073-49C6-9DE0-C39B32F90D1F","runtimeModeEnabled":false,"aiContextCloudSharingAllowed":false},"backgrounds":[{"id":"89732811-CD17-49B3-9242-59C9DD0424FA","stackId":"7FAC2126-3073-49C6-9DE0-C39B32F90D1F","sortKey":"a0","script":"","name":"Background 1"}],"aiContextLibrary":{"sources":[],"items":[]},"parts":[{"mapType":"standard","gaugeMin":0,"rotation":0,"visible":true,"gaugeDecimals":0,"popupItems":"","strokeColor":"#000000","chartData":"","textSize":14,"textStyle":"plain","dividerThickness":1,"transparentBackground":true,"dontWrap":false,"gaugeMaxLabel":"","colorWellHex":"#FF5500","pdfDisplayMode":"continuous","menuTitle":"Menu","name":"barrelClimberArea","gaugeValue":0,"controlValue":0,"shapeType":"rectangle","pdfURL":"","fieldStyle":"rectangle","mapAnnotationsJSON":"","buttonStyle":"default","invertOnClick":false,"colorWellInteractive":true,"selectedDate":"","searchText":"","segmentItems":"First|Second|Third","searchSendsImmediately":false,"strokeWidth":1,"scene3DAutoLighting":true,"textFont":"Apple Braille","progressValue":0,"controlStep":1,"script":"","scene3DBackground":"","width":800,"progressDecimals":0,"lockText":false,"pathData":[],"searchPrompt":"Search","gaugeMinLabel":"","mapLocation":"","animated":true,"dividerColor":"","textContent":"","progressLabel":"","helpText":"","gaugeMax":1,"dividerOrientation":"horizontal","cardId":"29928656-AB1D-45C9-94F8-638BABACC11E","fontColor":"","id":"760D8DB2-E618-44BB-97C0-338CD6DF0D13","progressTotal":1,"displayMonth":"","pdfAutoScales":true,"left":0,"sceneSpec":"{\"showsPhysics\":false,\"showsFPS\":false,\"showsNodeCount\":false,\"activeSceneID\":\"5614FC5E-1E5A-4E67-9221-9FFA8A7BC38E\",\"scenes\":[{\"id\":\"5614FC5E-1E5A-4E67-9221-9FFA8A7BC38E\",\"scene\":{\"showsPhysics\":false,\"showsFPS\":false,\"scaleMode\":\"aspectFit\",\"script\":\"global score, jumpSpeed, moveSpeed, barrelIndex\\nglobal heldA, heldD\\n\\non openScene\\n  global score, jumpSpeed, moveSpeed\\n  if score is empty then put 0 into score\\n  if jumpSpeed is empty then put 520 into jumpSpeed\\n  if moveSpeed is empty then put 220 into moveSpeed\\n\\n  set the affectedByGravity of sprite \\\"hero\\\" to true\\n  set the dynamic of sprite \\\"hero\\\" to true\\n\\n  put false into heldA\\n  put false into heldD\\n\\n  send \\\"resetPositions\\\" to me\\n  send \\\"resetBarrels\\\" to me\\nend openScene\\n\\non keyDown\\n  global jumpSpeed, moveSpeed\\n  global heldA, heldD\\n\\n  if the key is \\\"a\\\" then\\n    put true into heldA\\n    put false into heldD\\n    send \\\"applyHeroHorizontal\\\" to me\\n\\n  else if the key is \\\"d\\\" then\\n    put false into heldA\\n    put true into heldD\\n    send \\\"applyHeroHorizontal\\\" to me\\n\\n  else if the key is \\\"space\\\" then\\n    put the velocity of sprite \\\"hero\\\" into v\\n    set the velocity of sprite \\\"hero\\\" to (item 1 of v) & \\\",\\\" & (-jumpSpeed)\\n\\n  else\\n    pass keyDown\\n  end if\\nend keyDown\\n\\non keyUp\\n  global heldA, heldD\\n\\n  if the key is \\\"a\\\" then\\n    put false into heldA\\n    send \\\"applyHeroHorizontal\\\" to me\\n  else if the key is \\\"d\\\" then\\n    put false into heldD\\n    send \\\"applyHeroHorizontal\\\" to me\\n  end if\\nend keyUp\\n\\non applyHeroHorizontal\\n  global moveSpeed\\n  global heldA, heldD\\n\\n  put the velocity of sprite \\\"hero\\\" into v\\n  put item 2 of v into vy\\n\\n  if heldA and not heldD then\\n    set the velocity of sprite \\\"hero\\\" to (-moveSpeed) & \\\",\\\" & vy\\n  else if heldD and not heldA then\\n    set the velocity of sprite \\\"hero\\\" to moveSpeed & \\\",\\\" & vy\\n  else\\n    set the velocity of sprite \\\"hero\\\" to \\\"0,\\\" & vy\\n  end if\\nend applyHeroHorizontal\\n\\non newGame\\n  global score\\n  put 0 into score\\n  send \\\"resetPositions\\\" to me\\n  send \\\"resetBarrels\\\" to me\\nend newGame\\n\\non resetPositions\\n  set the loc of sprite \\\"hero\\\" to \\\"120,500\\\"\\n  set the velocity of sprite \\\"hero\\\" to \\\"0,0\\\"\\nend resetPositions\\n\\non resetBarrels\\n  global barrelIndex\\n  put 0 into barrelIndex\\n  send \\\"tossNextBarrel\\\" to me\\nend resetBarrels\\n\\non tossNextBarrel\\n  global barrelIndex\\n  add 1 to barrelIndex\\n  if barrelIndex > 5 then put 1 into barrelIndex\\n\\n  put \\\"barrel_\\\" & barrelIndex into b\\n\\n  set the loc of sprite b to \\\"150,70\\\"\\n  set the velocity of sprite b to \\\"220,0\\\"\\n  set the affectedByGravity of sprite b to true\\n  set the dynamic of sprite b to true\\n\\n  wait 1.0\\n  send \\\"tossNextBarrel\\\" to me\\nend tossNextBarrel\",\"fields\":[],\"joints\":[],\"nodes\":[{\"fontName\":\"Avenir Next Heavy\",\"yScale\":1,\"fontSize\":26,\"actions\":[],\"isHidden\":false,\"script\":\"\",\"position\":{\"y\":34,\"x\":400},\"children\":[],\"name\":\"titleLabel\",\"rotation\":0,\"zPosition\":60,\"text\":\"Barrel Climber\",\"xScale\":1,\"nodeType\":\"label\",\"fontColor\":\"#FFE66D\",\"id\":\"364BF102-5EA1-4F58-B95F-2CEE5A0309BF\",\"alpha\":1},{\"fontName\":\"Avenir Next Heavy\",\"yScale\":1,\"fontSize\":18,\"actions\":[],\"isHidden\":false,\"script\":\"\",\"position\":{\"y\":34,\"x\":92},\"children\":[],\"name\":\"scoreLabel\",\"rotation\":0,\"zPosition\":60,\"text\":\"Score: 0\",\"xScale\":1,\"nodeType\":\"label\",\"fontColor\":\"#FFFFFF\",\"id\":